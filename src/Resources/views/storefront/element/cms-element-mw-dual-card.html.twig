{% block element_mw_dual_card %}
    {% set c = element.config %}
    {% set features = element.data.rightFeatures ?? [] %}
    {% set rightBgMediaUrl = element.data.rightBgMediaUrl ?? c.rightBgMediaUrl.value ?? null %}

    <div class="cms-element-mw-dual-card">

        {# ── Left card ── #}
        <div
            class="mw-dual-card__left"
            style="background-color: {{ c.leftBgColor.value ?: '#1a1a1a' }}; color: {{ c.leftTextColor.value ?: '#ffffff' }};"
        >
            {% if c.leftHeading.value is not empty %}
                <h2 class="mw-dual-card__heading">{{ c.leftHeading.value }}</h2>
            {% endif %}

            {% if c.leftDescription.value is not empty %}
                <p class="mw-dual-card__description">{{ c.leftDescription.value }}</p>
            {% endif %}

            {% if c.leftBtnLabel.value is not empty %}
                <a
                    href="{{ c.leftLinkUrl.value ?: c.leftBtnUrl.value ?: '#' }}"
                    {% if c.leftBtnNewTab.value %}target="_blank" rel="noopener noreferrer"{% endif %}
                    class="mw-dual-card__btn"
                    style="
                        background-color: {{ c.leftBtnBgColor.value ?: '#ff6600' }};
                        color: {{ c.leftBtnTextColor.value ?: '#ffffff' }};
                        {% if c.leftBtnOutlineColor.value is not empty %}border: 2px solid {{ c.leftBtnOutlineColor.value }};{% endif %}
                    "
                >{{ c.leftBtnLabel.value }}</a>
            {% endif %}
        </div>

        {# ── Right card ── #}
        <div
            class="mw-dual-card__right"
            style="
                background-color: {{ c.rightBgColor.value ?: '#222222' }};
                {% if rightBgMediaUrl is not empty %}
                    background-image: url('{{ rightBgMediaUrl }}');
                    background-size: cover;
                    background-position: center;
                {% endif %}
                color: {{ c.rightTextColor.value ?: '#ffffff' }};
            "
        >
            {% if c.rightHeading.value is not empty %}
                <h2 class="mw-dual-card__heading">{{ c.rightHeading.value }}</h2>
            {% endif %}


            {% if features|length > 0 %}
                <ul class="mw-dual-card__features">
                    {% for feature in features %}
                        {% if feature.text is not empty %}
                            <li class="mw-dual-card__feature-item">
                                {% if feature.svgContent is not empty %}
                                    <span
                                        class="mw-dual-card__feature-icon mw-dual-card__feature-icon--svg"
                                        {% if feature.svgColor is not empty %}style="color: {{ feature.svgColor }};"{% endif %}
                                        aria-hidden="true"
                                    >{{ feature.svgContent|raw }}</span>
                                {% elseif feature.iconUrl is not empty and feature.iconUrl matches '/\\.svg(\\?.*)?$/' and feature.svgColor is not empty %}
                                    <span
                                        class="mw-dual-card__feature-icon"
                                        style="
                                            width: 18px;
                                            height: 18px;
                                            display: inline-block;
                                            background-color: {{ feature.svgColor }};
                                            -webkit-mask: url('{{ feature.iconUrl }}') no-repeat center;
                                            mask: url('{{ feature.iconUrl }}') no-repeat center;
                                            -webkit-mask-size: 18px 18px;
                                            mask-size: 18px 18px;
                                        "
                                        aria-hidden="true"
                                    ></span>
                                {% elseif feature.iconUrl is not empty %}
                                    <img
                                        src="{{ feature.iconUrl }}"
                                        alt=""
                                        class="mw-dual-card__feature-icon"
                                        width="18"
                                        height="18"
                                        loading="lazy"
                                    />
                                {% else %}
                                    <span class="mw-dual-card__feature-check" aria-hidden="true">✔</span>
                                {% endif %}
                                <span>{{ feature.text }}</span>
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            {% endif %}

            {% if c.rightBtnLabel.value is not empty %}
                <a
                    href="{{ c.rightLinkUrl.value ?: c.rightBtnUrl.value ?: '#' }}"
                    {% if c.rightBtnNewTab.value %}target="_blank" rel="noopener noreferrer"{% endif %}
                    class="mw-dual-card__btn"
                    style="
                        background-color: {{ c.rightBtnBgColor.value ?: '#ff6600' }};
                        color: {{ c.rightBtnTextColor.value ?: '#ffffff' }};
                        {% if c.rightBtnOutlineColor.value is not empty %}border: 2px solid {{ c.rightBtnOutlineColor.value }};{% endif %}
                    "
                >{{ c.rightBtnLabel.value }}</a>
            {% endif %}
        </div>

    </div>
{% endblock %}
