{% block element_mw_wheel_showcase %}
    {% set c = element.config %}
    {% set cards = element.data.cards ?? [] %}
    {% set title = element.data.title ?? '' %}
    {% set buttonText = element.data.buttonText ?? 'Jetzt Angebot anfordern!' %}
    {% set buttonLink = element.data.buttonLink ?? '' %}
    {% set show360 = element.data.show360 ?? true %}

    <div class="cms-element-mw-wheel-showcase mw-wheel-showcase" id="mw-wheel-showcase-{{ element.id }}" data-mw-wheel-showcase="true">
        {% if title is not empty %}
            <div class="mw-wheel-showcase__section-title">
                <h2>{{ title }}</h2>
            </div>
        {% endif %}

        <!-- Big Box containing details for the selected wheel -->
        <div class="mw-wheel-showcase__detail-container">
            {% for card in cards %}
                {% set product = card.product ?? null %}
                {% if product %}
                    {# Extract Themenbereich #}
                    {% set themenbereich = '' %}
                    {% if product.translated.customFields.custom_themenbereich is not empty %}
                        {% set themenbereich = product.translated.customFields.custom_themenbereich %}
                    {% elseif product.translated.customFields.themenbereich is not empty %}
                        {% set themenbereich = product.translated.customFields.themenbereich %}
                    {% else %}
                        {% for prop in product.properties %}
                            {% if prop.group.translated.name|lower == 'themenbereich' %}
                                {% set themenbereich = prop.translated.name %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    {# Extract Farbkategorie #}
                    {% set farbkategorie = '' %}
                    {% if product.translated.customFields.custom_farbkategorie is not empty %}
                        {% set farbkategorie = product.translated.customFields.custom_farbkategorie %}
                    {% elseif product.translated.customFields.farbkategorie is not empty %}
                        {% set farbkategorie = product.translated.customFields.farbkategorie %}
                    {% else %}
                        {% for prop in product.properties %}
                            {% if prop.group.translated.name|lower == 'farbkategorie' or prop.group.translated.name|lower == 'farbton' %}
                                {% set farbkategorie = prop.translated.name %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    {# Extract Oberflächenaufbau #}
                    {% set oberflaechenaufbau = '' %}
                    {% if product.translated.customFields.custom_oberflaechenaufbau is not empty %}
                        {% set oberflaechenaufbau = product.translated.customFields.custom_oberflaechenaufbau %}
                    {% elseif product.translated.customFields.oberflaechenaufbau is not empty %}
                        {% set oberflaechenaufbau = product.translated.customFields.oberflaechenaufbau %}
                    {% else %}
                        {% for prop in product.properties %}
                            {% if prop.group.translated.name|lower == 'oberflächenaufbau' or prop.group.translated.name|lower == 'oberflachenaufbau' %}
                                {% set oberflaechenaufbau = prop.translated.name %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    {# Extract Bearbeitungsschritte #}
                    {% set bearbeitungsschritte = [] %}
                    {% if product.translated.customFields.custom_bearbeitungsschritte is not empty %}
                        {% if product.translated.customFields.custom_bearbeitungsschritte is iterable %}
                            {% set bearbeitungsschritte = product.translated.customFields.custom_bearbeitungsschritte %}
                        {% else %}
                            {% set bearbeitungsschritte = product.translated.customFields.custom_bearbeitungsschritte|split('\n') %}
                        {% endif %}
                    {% elseif product.translated.customFields.bearbeitungsschritte is not empty %}
                        {% if product.translated.customFields.bearbeitungsschritte is iterable %}
                            {% set bearbeitungsschritte = product.translated.customFields.bearbeitungsschritte %}
                        {% else %}
                            {% set bearbeitungsschritte = product.translated.customFields.bearbeitungsschritte|split('\n') %}
                        {% endif %}
                    {% else %}
                        {% for prop in product.properties %}
                            {% if prop.group.translated.name|lower == 'bearbeitungsschritte' or prop.group.translated.name|lower == 'bearbeitungsschritt' %}
                                {% set bearbeitungsschritte = bearbeitungsschritte|merge([prop.translated.name]) %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    {# Extract Gallery Images #}
                    {% set galleryImages = [] %}
                    {% if product.media is not empty %}
                        {% for item in product.media|sort((a, b) => a.position <=> b.position) %}
                            {% if item.media %}
                                {% set galleryImages = galleryImages|merge([item.media]) %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                    {% if galleryImages is empty and product.cover.media %}
                        {% set galleryImages = [product.cover.media] %}
                    {% endif %}

                    {# Format Price #}
                    {% set price = '' %}
                    {% if product.calculatedPrice %}
                        {% set price = product.calculatedPrice.unitPrice|currency %}
                    {% elseif product.price is not empty %}
                        {# Fallback if calculated price is not set #}
                        {% set price = product.price[0].gross|currency %}
                    {% endif %}

                    <div class="mw-wheel-showcase__detail-box {% if loop.first %}is--active{% endif %}" data-wheel-id="{{ product.id }}">
                        <div class="mw-wheel-showcase__media-area">
                            <!-- Big Active Image -->
                            <div class="mw-wheel-showcase__big-image">
                                {% if product.cover.media %}
                                    <img src="{{ product.cover.media.url }}" alt="{{ product.translated.name }}" class="js-showcase-big-img" />
                                {% else %}
                                    <div class="mw-wheel-showcase__placeholder-img">No Image</div>
                                {% endif %}
                            </div>

                            <!-- Gallery Thumbnails -->
                            {% if galleryImages|length > 1 %}
                                <div class="mw-wheel-showcase__gallery-thumbs">
                                    {% for img in galleryImages %}
                                        <div class="mw-wheel-showcase__gallery-thumb {% if loop.first %}is--active{% endif %}" data-img-src="{{ img.url }}">
                                            <img src="{{ img.url }}" alt="{{ product.translated.name }}" />
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="mw-wheel-showcase__info-area">
                            <div class="mw-wheel-showcase__header">
                                <h3 class="mw-wheel-showcase__product-name">{{ product.translated.name }}</h3>
                                <div class="mw-wheel-showcase__subtitle">
                                    {{ card.title ?: 'Felgen Pulver + Lack: ' ~ product.translated.name }}
                                </div>
                            </div>

                            <div class="mw-wheel-showcase__attributes">
                                {% if themenbereich is not empty %}
                                    <div class="mw-wheel-showcase__attr-row">
                                        <span class="mw-wheel-showcase__attr-label">Themenbereich:</span>
                                        <span class="mw-wheel-showcase__attr-value">{{ themenbereich }}</span>
                                    </div>
                                {% endif %}

                                {% if farbkategorie is not empty %}
                                    <div class="mw-wheel-showcase__attr-row">
                                        <span class="mw-wheel-showcase__attr-label">Farbkategorie:</span>
                                        <span class="mw-wheel-showcase__attr-value">{{ farbkategorie }}</span>
                                    </div>
                                {% endif %}

                                {% if oberflaechenaufbau is not empty %}
                                    <div class="mw-wheel-showcase__attr-row">
                                        <span class="mw-wheel-showcase__attr-label">Oberflächenaufbau:</span>
                                        <span class="mw-wheel-showcase__attr-value">{{ oberflaechenaufbau }}</span>
                                    </div>
                                {% endif %}
                            </div>

                            {% if bearbeitungsschritte is not empty %}
                                <div class="mw-wheel-showcase__steps-section">
                                    <div class="mw-wheel-showcase__steps-title">Bearbeitungsschritte</div>
                                    <ul class="mw-wheel-showcase__steps-list">
                                        {% for step in bearbeitungsschritte %}
                                            {% if step|trim is not empty %}
                                                <li>{{ step|trim }}</li>
                                            {% endif %}
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% endif %}

                            <div class="mw-wheel-showcase__footer-actions">
                                {% if price is not empty %}
                                    <div class="mw-wheel-showcase__price-info">
                                        Je Felge ab {{ price }} inkl. MwSt.
                                    </div>
                                {% endif %}

                                <div class="mw-wheel-showcase__buttons">
                                    {% set targetLink = buttonLink ?: seoUrl('frontend.detail.page', { productId: product.id }) %}
                                    <a href="{{ targetLink }}" class="btn btn-primary mw-wheel-showcase__action-btn">
                                        {{ buttonText }}
                                    </a>
                                </div>

                                {% if show360 %}
                                    <div class="mw-wheel-showcase__360-badge">
                                        <span class="mw-wheel-showcase__360-label">zur 360° Ansicht wechseln</span>
                                        <div class="mw-wheel-showcase__360-graphic">
                                            <svg viewBox="0 0 100 60" class="mw-wheel-showcase__360-svg">
                                                <path d="M 10 30 C 10 45, 90 45, 90 30 C 90 15, 10 15, 10 30" fill="none" stroke="#222" stroke-width="3" stroke-dasharray="8 4" />
                                                <polygon points="50,40 60,45 50,50" fill="#222" />
                                                <text x="50" y="35" font-size="16" font-weight="bold" text-anchor="middle" fill="#222">360°</text>
                                            </svg>
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>

        <!-- Horizontal scrollable row of all wheels -->
        <div class="mw-wheel-showcase__list-row">
            {% for card in cards %}
                {% set product = card.product ?? null %}
                {% if product %}
                    <div class="mw-wheel-showcase__list-item {% if loop.first %}is--active{% endif %}" data-target-wheel-id="{{ product.id }}">
                        <div class="mw-wheel-showcase__list-item-media">
                            {% if product.cover.media %}
                                <img src="{{ product.cover.media.url }}" alt="{{ product.translated.name }}" />
                            {% else %}
                                <div class="mw-wheel-showcase__list-item-placeholder">No Image</div>
                            {% endif %}
                        </div>
                        <div class="mw-wheel-showcase__list-item-name">
                            {{ product.translated.name }}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
{% endblock %}
