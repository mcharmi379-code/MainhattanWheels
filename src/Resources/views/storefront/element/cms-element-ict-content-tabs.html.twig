{% block element_ict_content_tabs %}
    {% set config = element.translated.config ?? element.config %}
    {% set tabs = element.data.tabs ?? config.tabs.value ?? [] %}
    {% set activeTabColor = config.activeTabColor.value ?? '#e30613' %}

    {% if tabs|length > 0 %}
        <div
            class="cms-element-ict-content-tabs"
            data-ict-content-tabs="true"
            style="--ict-ct-active-color: {{ activeTabColor|e('html_attr') }};"
        >

            <div class="ict-ct__nav" role="tablist">
                {% for tab in tabs %}
                    <button
                        type="button"
                        class="ict-ct__nav-item{% if loop.first %} ict-ct__nav-item--active{% endif %}"
                        data-tab-index="{{ loop.index0 }}"
                        role="tab"
                        aria-selected="{{ loop.first ? 'true' : 'false' }}"
                    >
                        {{ tab.label|default('Tab ' ~ loop.index)|e }}
                    </button>
                {% endfor %}
            </div>

            <div class="ict-ct__panels">
                {% for tab in tabs %}
                    <div
                        class="ict-ct__panel{% if loop.first %} ict-ct__panel--active{% endif %}"
                        role="tabpanel"
                        {% if not loop.first %}hidden{% endif %}
                    >
                        {{ tab.content|raw }}
                    </div>
                {% endfor %}
            </div>

        </div>

        <script>
            (function () {
                const root = document.currentScript && document.currentScript.previousElementSibling
                    ? (document.currentScript.previousElementSibling.matches('[data-ict-content-tabs="true"]') 
                        ? document.currentScript.previousElementSibling 
                        : document.currentScript.previousElementSibling.querySelector('[data-ict-content-tabs="true"]'))
                    : null;

                if (!root || root.dataset.ictContentTabsInitialized === '1') {
                    return;
                }

                root.dataset.ictContentTabsInitialized = '1';

                const triggers = root.querySelectorAll('.ict-ct__nav-item');
                const panels = root.querySelectorAll('.ict-ct__panel');

                triggers.forEach((trigger) => {
                    trigger.addEventListener('click', () => {
                        const index = parseInt(trigger.getAttribute('data-tab-index'), 10);

                        triggers.forEach((button) => {
                            const isActive = button === trigger;
                            button.classList.toggle('ict-ct__nav-item--active', isActive);
                            button.setAttribute('aria-selected', isActive ? 'true' : 'false');
                        });

                        panels.forEach((panel, i) => {
                            const isActive = i === index;
                            panel.classList.toggle('ict-ct__panel--active', isActive);
                            if (isActive) {
                                panel.removeAttribute('hidden');
                            } else {
                                panel.setAttribute('hidden', '');
                            }
                        });
                    });
                });
            })();
        </script>
    {% endif %}
{% endblock %}
