{% sw_extends '@Storefront/storefront/layout/header/header.html.twig' %}

{% set showToolbar = config('TcinnA11yToolbarApp.config.TcinnA11yToolbarShow') %}
{% set position = config('TcinnA11yToolbarApp.config.TcinnA11yToolbarPosition') %}
{% set initState = config('TcinnA11yToolbarApp.config.TcinnA11yToolbarInitialState') %}
{% set iconVariant = config('TcinnA11yToolbarApp.config.TcinnA11yToolbarIconVariant') %}

