{# anhand der eingestellten Variante das tatsächliche svgShow setzen #}
{% if iconVariant == 'universal-access' %}
  {% set svgShow = svgUniversalAccess %}
{% elseif iconVariant == 'universal-access-circle' %}
  {% set svgShow = svgUniversalAccessCircle %}
{% elseif iconVariant == 'person-wheelchair' %}
  {% set svgShow = svgPersonWheelchair %}
{% elseif iconVariant == 'wheelchair-upright' %}
  {% set svgShow = svgWheelchairUpright %}
{% else %}
  {# Fallback, falls jemand einen ungültigen Wert in den Einstellungen hat #}
  {% set svgShow = svgUniversalAccess %}
{% endif %}


{% block layout_header_navigation %}
    <div class="main-hattan-wheels-header">
        {% block layout_header_logo %}
            <div class="header-logo-col">
                {% sw_include '@Storefront/storefront/layout/header/logo.html.twig' %}
            </div>
        {% endblock %}

        {% block base_navigation %}
            <div class="nav-main">
                {% block base_navigation_inner %}
                    {% sw_include '@Storefront/storefront/layout/navigation/navigation.html.twig' %}
                {% endblock %}
                <div class="header-navigation-aerrow">
                
                </div>
            </div>
        {% endblock %}

    {% block layout_header_search %}
        <div class="col-12 order-2 col-sm order-sm-1 header-search-col">
            <div class="row">
                <div class="col-sm-auto d-none d-sm-block d-lg-none navigation-section">
                    {% block layout_header_navigation_toggle_tablet %}
                        <div class="nav-main-toggle">
                            {% block layout_header_navigation_toggle_tablet_button %}
                                <button
                                        class="btn nav-main-toggle-btn header-actions-btn"
                                        type="button"
                                        {# @deprecated tag:v6.6.0 - Registering plugin on selector "data-offcanvas-menu" is deprecated. Use "data-off-canvas-menu" instead #}
                                        {% if feature('v6.6.0.0') %}
                                            data-off-canvas-menu="true"
                                        {% else %}
                                            data-offcanvas-menu="true"
                                        {% endif %}
                                        aria-label="{{ "general.menuLink"|trans|striptags }}"
                                >
                                    {% block layout_header_navigation_toggle_tablet_button_icon %}
                                        {% sw_icon 'stack' %}
                                    {% endblock %}
                                </button>
                            {% endblock %}
                        </div>
                    {% endblock %}
                </div>
                <div class="col">
                    {% sw_include '@Storefront/storefront/layout/header/search.html.twig' %}
                </div>
            </div>
        </div>
    {% endblock %}


    {% block layout_header_actions %}
        <div class="header-actions-mobile">
            <div class="row g-0">
                {% block layout_header_navigation_toggle %}
                    <div class="col d-lg-none order-2 flex-grow-0">
                        <div class="menu-button ">
                            {% block layout_header_navigation_toggle_button %}
                                <button
                                        class="btn nav-main-toggle-btn header-actions-btn main-hattan-mobile-menu"
                                        type="button"
                                        id="main-hattan-cookie-button"
                                        {# @deprecated tag:v6.6.0 - Registering plugin on selector "data-offcanvas-menu" is deprecated. Use "data-off-canvas-menu" instead #}
                                        {% if feature('v6.6.0.0') %}
                                            data-off-canvas-menu="true"
                                        {% else %}
                                            data-offcanvas-menu="true"
                                        {% endif %}
                                        aria-label="{{ "general.menuLink"|trans|striptags }}"
                                >
                                    {% block layout_header_navigation_toggle_button_icon %}
                                        {% sw_icon 'stack' %}
                                    {% endblock %}
                                </button>
                            {% endblock %}
                        </div>
                    </div>

                    <div class="col-auto order-1">
                        <div class="search-toggle">
                            <button class="btn header-actions-btn search-toggle-btn js-search-toggle-btn collapsed main-hattan-search-button-for-css"
                                    id="closeToggle"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#searchCollapse"
                                    aria-expanded="false"
                                    aria-controls="searchCollapse"
                                    aria-label="{{ "header.searchButton"|trans|striptags }}">
                                {% sw_icon 'search' %}
                            </button>
                            {% sw_include '@Storefront/storefront/layout/header/search.html.twig' %}
                        </div>
                    </div>
                {% endblock %}
            </div>
        </div>
        <div class="header-actions-col">
            <div class="row g-0">
                {% block layout_header_search_toggle %}

    {# Toolbar nur dann im Header ausgeben #}
    {% if showToolbar and position == 'header-action' %}
        {% block tcinnA11y_toolbar_wrapper_header_toggle %}
            {# Show-Button immer vorhanden #}
            {% if position == 'header-action' %}
                {% block tcinnA11y_toolbar_show_button %}
                <div class="col-auto">
                    <button
                        id="show-toolbar-button" class="btn header-actions-btn tcinn-accessibility-toolbar-button toolbar-show-button {{ position }}{% if initState != 'closed' %} hidden{% endif %}" type="button"
                        aria-controls="tcinn-a11y-toolbar"
                        aria-expanded="{{ initState != 'closed' ? 'false' : 'true' }}"
                        aria-label="{{ 'tcinn-a11y-toolbar.show'|trans }}"
                        title="{{ 'tcinn-a11y-toolbar.show'|trans }}" tabindex="0">
                        <span class="icon tcinn-icon-a11y">
                            {{ svgShow|raw }}
                        </span>
                        <span class="label visually-hidden">{{ 'tcinn-a11y-toolbar.show'|trans }}</span>
                    </button>
                </div>
                {% endblock %}
            {% endif %}
        {% endblock %}
    {% endif %}

                    <div class="main-hattan-custom-theme d-flex">
                        {% if config('core.cart.wishlistEnabled') %}
                            {% block layout_header_actions_wishlist %}
                                <div class="col-auto order-4">
                                    <div class="header-wishlist">
                                        <a class="btn header-wishlist-btn header-actions-btn"
                                           href="{{ path('frontend.wishlist.page') }}"
                                           title="{{ 'header.wishlist'|trans|striptags }}"
                                           aria-label="{{ 'header.wishlist'|trans|striptags }}">
                                            {% sw_include '@Storefront/storefront/layout/header/actions/wishlist-widget.html.twig' %}
                                        </a>
                                    </div>
                                </div>
                            {% endblock %}
                        {% endif %}

                        {% block layout_header_actions_account %}
                            <div class="col-auto order-3">
                                <div class="account-menu">
                                    {% sw_include '@Storefront/storefront/layout/header/actions/account-widget.html.twig' %}
                                </div>
                            </div>
                        {% endblock %}

                        {% block layout_header_actions_cart %}
                            <div class="col-auto order-4">
                                <div
                                        class="header-cart"
                                        {#                                             @deprecated tag:v6.6.0 - Registering plugin on selector "data-offcanvas-cart" is deprecated. Use "data-off-canvas-cart" instead #}
                                        {% if feature('v6.6.0.0') %}
                                            data-off-canvas-cart="true"
                                        {% else %}
                                            data-offcanvas-cart="true"
                                        {% endif %}
                                >
                                    <a class="btn header-cart-btn header-actions-btn"
                                       href="{{ path('frontend.checkout.cart.page') }}"
                                       data-cart-widget="true"
                                       title="{{ 'checkout.cartTitle'|trans|striptags }}"
                                       aria-label="{{ 'checkout.cartTitle'|trans|striptags }}">
                                        {% sw_include '@Storefront/storefront/layout/header/actions/cart-widget.html.twig' %}
                                    </a>
                                </div>
                            </div>
                        {% endblock %}
                    </div>
                {% endblock %}

                {% sw_include '@Storefront/storefront/component/header/mainhattan-header-social-media.html.twig' %}
            </div>
        </div>


    </div>
{% endblock %}
