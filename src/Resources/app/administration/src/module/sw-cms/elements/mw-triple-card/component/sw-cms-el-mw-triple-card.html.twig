{% block sw_cms_el_mw_triple_card %}
    <div class="sw-cms-el-mw-triple-card">

        <div
            class="sw-cms-el-mw-triple-card__left"
            :style="{
                backgroundColor: c.leftBgColor?.value,
                backgroundImage: c.leftBgType?.value === 'image' && c.leftBgMediaUrl?.value ? 'url(' + c.leftBgMediaUrl.value + ')' : 'none',
                backgroundSize: 'cover',
                backgroundPosition: 'center',
            }"
        >
            <span class="tc-el-headline" :style="{ color: c.leftHeadingColor?.value || 'inherit' }">{{ c.leftHeadline?.value || 'Headline' }}</span>
            <template v-if="leftIcons.length">
                <div v-for="(item, i) in leftIcons" :key="i" class="tc-el-icon-item">
                    <img
                        v-if="item.iconUrl"
                        :src="item.iconUrl"
                        alt=""
                        class="tc-el-icon"
                        :style="{ color: item.iconColor || 'inherit' }"
                    />
                    <span v-else class="tc-el-icon-placeholder">⚙</span>
                    <span v-if="item.iconDesc" class="tc-el-desc" :style="{ color: item.iconTextColor || 'inherit' }">{{ item.iconDesc }}</span>
                </div>
            </template>
            <template v-else>
                <span class="tc-el-icon-placeholder">⚙</span>
                <span class="tc-el-desc">Icon description</span>
            </template>
        </div>

        <div
            class="sw-cms-el-mw-triple-card__mid"
            :style="{
                backgroundColor: c.midBgColor?.value,
                backgroundImage: c.midBgType?.value === 'image' && c.midBgMediaUrl?.value ? 'url(' + c.midBgMediaUrl.value + ')' : 'none',
                backgroundSize: 'cover',
                backgroundPosition: 'center',
            }"
        >
            <span class="tc-el-sub">{{ c.midSubHeading?.value || 'Sub Heading' }}</span>
            <span class="tc-el-headline">{{ c.midHeading?.value || 'Heading' }}</span>
            <p class="tc-el-desc">{{ c.midDescription?.value || 'Description…' }}</p>
            <span
                v-if="c.midBtnLabel?.value"
                class="tc-el-btn"
                :style="{
                    backgroundColor: c.midBtnBgColor?.value,
                    color: c.midBtnTextColor?.value,
                    border: c.midBtnBorderColor?.value ? '2px solid ' + c.midBtnBorderColor.value : 'none',
                }"
            >{{ c.midBtnLabel?.value }}</span>
            <div v-if="c.midIconText?.value" class="tc-el-after-btn">
                <span :style="{ color: c.midIconTextColor?.value || 'inherit' }">{{ c.midIconText?.value }}</span>
                <img
                    v-if="c.midIconUrl?.value"
                    :src="c.midIconUrl.value"
                    alt=""
                    class="tc-el-small-icon"
                    :style="{ color: c.midIconColor?.value || 'inherit' }"
                />
            </div>
        </div>

        <div
            class="sw-cms-el-mw-triple-card__right"
            :style="{
                backgroundColor: c.rightBgColor?.value,
                backgroundImage: c.rightBgType?.value === 'image' && c.rightBgMediaUrl?.value ? 'url(' + c.rightBgMediaUrl.value + ')' : 'none',
                backgroundSize: 'cover',
                backgroundPosition: 'center',
                color: c.rightTextColor?.value,
            }"
        >
            <div v-if="c.rightHeading?.value" class="tc-el-right-heading">{{ c.rightHeading?.value }}</div>
            <p class="tc-el-desc">{{ c.rightDescription?.value || 'Description…' }}</p>
            <div v-if="c.rightIconText?.value" class="tc-el-icon-text-row">
                <span :style="{ color: c.rightIconTextColor?.value || 'inherit' }">{{ c.rightIconText?.value }}</span>
                <img
                    v-if="c.rightIconUrl?.value"
                    :src="c.rightIconUrl.value"
                    alt=""
                    class="tc-el-small-icon"
                    :style="{ color: c.rightIconColor?.value || 'inherit' }"
                />
            </div>
        </div>

    </div>
{% endblock %}
