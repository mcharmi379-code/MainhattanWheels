{% block sw_cms_element_ict_hero_section %}
    <div
        class="sw-cms-el-ict-hero-section"
        :style="{
            minHeight: element.config.minHeight.value,
            background: element.config.backgroundType.value === 'color'
                ? element.config.backgroundColor.value
                : element.config.backgroundType.value === 'image' && element.data && element.data.backgroundMedia && element.data.backgroundMedia.url
                    ? `url(${element.data.backgroundMedia.url}) center / cover no-repeat`
                    : element.config.backgroundType.value === 'video'
                        ? '#1a1a2e'
                        : `linear-gradient(135deg, ${element.config.backgroundGradientColor1.value}, ${element.config.backgroundGradientColor2.value})`
        }"
    >
        <video
            v-if="element.config.backgroundType.value === 'video' && element.data && element.data.video && element.data.video.url"
            class="sw-cms-el-ict-hero-section__video-bg"
            autoplay
            loop
            muted
            playsinline
            :src="element.data.video.url"
        ></video>

        <div class="sw-cms-el-ict-hero-section__left" :class="textAlignmentClass">
            <span
                v-if="element.config.labelText.value"
                class="sw-cms-el-ict-hero-section__label"
                :style="labelStyle"
            >
                {{ element.config.labelText.value }}
            </span>

            <h2
                class="sw-cms-el-ict-hero-section__headline"
                :style="{ color: element.config.headlineColor.value }"
            >
                {{ element.config.headlineText.value }}
            </h2>

            <div
                class="sw-cms-el-ict-hero-section__description"
                :style="{ color: element.config.descriptionColor.value }"
                v-html="element.config.descriptionText.value"
            >
            </div>

            <div class="sw-cms-el-ict-hero-section__actions">
                <button
                    class="sw-cms-el-ict-hero-section__button sw-cms-el-ict-hero-section__button--primary"
                    :style="{
                        backgroundColor: element.config.primaryButtonBackgroundColor.value,
                        color: element.config.primaryButtonTextColor.value
                    }"
                >
                    {{ element.config.primaryButtonText.value }}
                </button>
                <button
                    v-if="element.config.showSecondaryButton.value"
                    class="sw-cms-el-ict-hero-section__button sw-cms-el-ict-hero-section__button--secondary"
                    :style="{
                        backgroundColor: element.config.secondaryButtonBackgroundColor.value,
                        color: element.config.secondaryButtonTextColor.value
                    }"
                >
                    {{ element.config.secondaryButtonText.value }}
                </button>
            </div>
        </div>

        <div v-if="element.config.textAlignment.value !== 'center'" class="sw-cms-el-ict-hero-section__right">
            <img
                v-if="element.config.backgroundType.value === 'image' && element.data && element.data.backgroundMedia && element.data.backgroundMedia.url"
                class="sw-cms-el-ict-hero-section__image"
                :src="element.data.backgroundMedia.url"
                alt=""
            >
            <div
                v-else-if="element.config.backgroundType.value !== 'video'"
                class="sw-cms-el-ict-hero-section__image-placeholder"
            >
                BG
            </div>
        </div>

    </div>
{% endblock %}
