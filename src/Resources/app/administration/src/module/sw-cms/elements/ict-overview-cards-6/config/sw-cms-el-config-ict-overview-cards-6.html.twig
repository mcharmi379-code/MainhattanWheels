                                </sw-upload-listener>

                                <sw-media-upload-v2
                                    variant="regular"
                                    :upload-tag="getCardVideoUploadTag(cardIndex)"
                                    :source="getCardVideoMediaItem(cardIndex)"
                                    :allow-multi-select="false"
                                    :label="$tc('sw-cms.elements.ictOverviewCards.config.label.cardBackgroundVideo')"
                                    :default-folder="'cms_page'"
                                    :file-accept="'video/*'"
                                    @selection-change="onCardVideoSelectionChanges(cardIndex, $event)"
                                    @media-upload-remove-image="onCardVideoRemove(cardIndex)"
