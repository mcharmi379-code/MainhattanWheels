                                @update:value="updateCard(cardIndex, 'cardBackgroundVideoUploadUrl', $event)">
                            </mt-text-field>

                            <div v-if="card.cardBackgroundVideoUploadType === 'file'">
                                <sw-upload-listener
                                    :upload-tag="getCardVideoUploadTag(cardIndex)"
                                    @media-upload-finish="onCardVideoUpload(cardIndex, $event)"
