                        <div v-if="card.cardBackgroundType === 'image'" class="image-upload-field">
                            <sw-upload-listener
                                :upload-tag="getCardImageUploadTag(cardIndex)"
                                @media-upload-finish="onCardImageUpload(cardIndex, $event)"
                                auto-upload>
                            </sw-upload-listener>

                            <sw-media-upload-v2
                                variant="regular"
                                :upload-tag="getCardImageUploadTag(cardIndex)"
                                :source="getCardImageMediaItem(cardIndex)"
                                :allow-multi-select="false"
                                :label="$tc('sw-cms.elements.ictOverviewCards.config.label.cardBackgroundImage')"
