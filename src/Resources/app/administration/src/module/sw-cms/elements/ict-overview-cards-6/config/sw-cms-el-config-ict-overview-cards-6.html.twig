                        <div class="field-subgroup">
                            <mt-select
                                v-model="card.cardMainBackgroundType"
                                label="Main card background type"
                                :options="cardBackgroundTypeOptions"
                                @update:value="onElementUpdate">
                            </mt-select>

                            <sw-colorpicker v-if="card.cardMainBackgroundType === 'color'"
                                v-model:value="card.cardMainBackgroundColor"
                                color-output="hex"
                                :z-index="1000"
                                label="Main background color"
                                @update:value="onElementUpdate">
                            </sw-colorpicker>

                            <div v-if="card.cardMainBackgroundType === 'gradient'" class="gradient-fields">
                                <div class="inline-fields">
                                    <sw-colorpicker
                                        v-model:value="card.cardMainBackgroundGradientColor1"
                                        color-output="hex"
                                        :z-index="1000"
                                        label="Gradient color 1"
                                        @update:value="onElementUpdate">
                                    </sw-colorpicker>
                                    <sw-colorpicker
                                        v-model:value="card.cardMainBackgroundGradientColor2"
                                        color-output="hex"
                                        :z-index="1000"
                                        label="Gradient color 2"
                                        @update:value="onElementUpdate">
                                    </sw-colorpicker>
                                </div>
                                <mt-select
                                    v-model="card.cardMainBackgroundGradientDirection"
                                    label="Gradient direction"
                                    :options="gradientDirectionOptions"
                                    @update:value="onElementUpdate">
                                </mt-select>
                            </div>

                            <div v-if="card.cardMainBackgroundType === 'image'" class="image-upload-field">
                                <sw-upload-listener
                                    :upload-tag="getCardMainImageUploadTag(cardIndex)"
                                    @media-upload-finish="onCardMainImageUpload(cardIndex, $event)"
                                    auto-upload>
                                </sw-upload-listener>

                                <sw-media-upload-v2
                                    variant="regular"
                                    :upload-tag="getCardMainImageUploadTag(cardIndex)"
                                    :source="getCardMainImageMediaItem(cardIndex)"
                                    :allow-multi-select="false"
                                    label="Main background image"
                                    :default-folder="'cms_page'"
                                    @selection-change="onCardMainImageSelectionChanges(cardIndex, $event)"
                                    @media-upload-remove-image="onCardMainImageRemove(cardIndex)"
                                    @media-upload-sidebar-open="onOpenCardMainImageModal(cardIndex)">
                                </sw-media-upload-v2>

                                <sw-media-modal-v2
                                    v-if="cardMainImageModals[cardIndex]"
                                    :initial-folder-id="null"
                                    :entity-context="'cms_page'"
                                    @media-modal-selection-change="onCardMainImageSelectionChanges(cardIndex, $event)"
                                    @modal-close="onCloseCardMainImageModal(cardIndex)">
                                </sw-media-modal-v2>
                            </div>

                            <div v-if="card.cardMainBackgroundType === 'video'" class="video-upload-field">
                                <mt-select
                                    v-model="card.cardMainBackgroundVideoUploadType"
                                    label="Main background video type"
                                    :options="videoUploadOptions"
                                    @update:value="updateCard(cardIndex, 'cardMainBackgroundVideoUploadType', $event)">
                                </mt-select>

                                <mt-text-field v-if="card.cardMainBackgroundVideoUploadType === 'url'"
                                    v-model="card.cardMainBackgroundVideoUploadUrl"
                                    label="Main background video URL"
                                    @update:value="updateCard(cardIndex, 'cardMainBackgroundVideoUploadUrl', $event)">
                                </mt-text-field>

                                <div v-if="card.cardMainBackgroundVideoUploadType === 'file'">
                                    <sw-upload-listener
                                        :upload-tag="getCardMainVideoUploadTag(cardIndex)"
                                        @media-upload-finish="onCardMainVideoUpload(cardIndex, $event)"
                                        auto-upload>
                                    </sw-upload-listener>

                                    <sw-media-upload-v2
                                        variant="regular"
                                        :upload-tag="getCardMainVideoUploadTag(cardIndex)"
                                        :source="getCardMainVideoMediaItem(cardIndex)"
                                        :allow-multi-select="false"
                                        label="Main background video"
                                        :default-folder="'cms_page'"
                                        :file-accept="'video/*'"
                                        @selection-change="onCardMainVideoSelectionChanges(cardIndex, $event)"
                                        @media-upload-remove-image="onCardMainVideoRemove(cardIndex)"
                                        @media-upload-sidebar-open="onOpenCardMainVideoModal(cardIndex)">
                                    </sw-media-upload-v2>

                                    <sw-media-modal-v2
                                        v-if="cardMainVideoModals[cardIndex]"
                                        :initial-folder-id="null"
                                        :entity-context="'cms_page'"
                                        @media-modal-selection-change="onCardMainVideoSelectionChanges(cardIndex, $event)"
                                        @modal-close="onCloseCardMainVideoModal(cardIndex)">
                                    </sw-media-modal-v2>
                                </div>
                            </div>
                        </div>

                        <div class="field-subgroup">
