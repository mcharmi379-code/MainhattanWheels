                    <sw-button @click="removeCard(cardIndex)" size="small" variant="danger" class="remove-card-button">
                        {{ $tc('sw-cms.elements.ictOverviewCards.config.button.removeCard') }}
                    </sw-button>
                </div>

                </div><!-- close card-item-content -->
                </div><!-- close ict-accordion-content -->
                </div><!-- close ict-accordion -->
            </div><!-- close v-for card-config -->
        </div><!-- close card-management -->

    </div><!-- close sw-cms-el-config-ict-overview-cards -->
