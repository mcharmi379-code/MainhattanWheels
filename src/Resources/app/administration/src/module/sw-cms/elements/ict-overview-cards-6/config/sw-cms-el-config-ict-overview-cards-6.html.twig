                            :z-index="1000"
                            :label="$tc('sw-cms.elements.ictOverviewCards.config.label.cardBackgroundColor')"
                            @update:value="onElementUpdate">
                        </sw-colorpicker>

                        <div v-if="card.cardBackgroundType === 'gradient'" class="gradient-fields">
                            <div class="inline-fields">
                                <sw-colorpicker
                                    v-model:value="card.cardBackgroundGradientColor1"
                                    color-output="hex"
                                    :z-index="1000"
                                    :label="$tc('sw-cms.elements.ictOverviewCards.config.label.gradientColor1')"
