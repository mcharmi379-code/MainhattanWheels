<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false" />

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwProductGridCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver" />
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwProductCarouselCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver" />
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwButtonsCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver" />
            <argument>%kernel.project_dir%</argument>
        </service>

        <!-- Decorator / Form Controller -->
        <service id="MainhattanWheels\Storefront\Controller\NewsletterFormController" public="true">
            <argument type="service" id="Shopware\Core\Content\ContactForm\SalesChannel\ContactFormRoute"/>
            <argument type="service" id="Shopware\Core\Content\Newsletter\SalesChannel\NewsletterSubscribeRoute"/>
            <argument type="service" id="Shopware\Core\Content\Newsletter\SalesChannel\NewsletterUnsubscribeRoute"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <call method="setTwig">
                <argument type="service" id="twig"/>
            </call>
            <tag name="controller.service_arguments"/>
        </service>

        <!-- Resolver -->
        <service id="MainhattanWheels\Core\Content\Media\Cms\mainhattanImageTextCmsElementResolver">
            <tag name="shopware.cms.data_resolver"/>
            <argument type="service" id="Shopware\Core\Content\Media\Cms\DefaultMediaResolver"/>
        </service>

        <!-- Restored original services -->
        <service id="MainhattanWheels\Core\Content\Media\Cms\IctHeroSectionElementDataResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\Helper\Category\ResolveCategoryEntity"/>
        <service id="MainhattanWheels\Core\Content\Cms\Helper\Category\MapCategoryCard">
            <argument type="service" id="MainhattanWheels\Core\Content\Cms\Helper\Category\ResolveCategoryEntity"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\Helper\Category\BuildCategoryCard">
            <argument type="service" id="MainhattanWheels\Core\Content\Cms\Helper\Category\MapCategoryCard"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\Helper\Category\ExtractCategoryIds"/>

        <service id="MainhattanWheels\Core\Content\Cms\IctCategoryImageSliderCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
            <argument type="service" id="MainhattanWheels\Core\Content\Cms\Helper\Category\ExtractCategoryIds"/>
            <argument type="service" id="MainhattanWheels\Core\Content\Cms\Helper\Category\BuildCategoryCard"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MainhattanIconFeatureBarCmsElementResolver" public="true">
            <argument>%kernel.project_dir%</argument>
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwCategoryShowcaseCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwDualCardCmsElementResolver" public="true">
            <argument>%kernel.project_dir%</argument>
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwTripleCardCmsElementResolver" public="true">
            <argument>%kernel.project_dir%</argument>
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwHeroBannerCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwProfileTabsCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\IctContentTabsCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\IctOverviewCards6CmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwFileDownloadCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwSubcategoryGridCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>
    <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\IctSingleTitleButtonSectionCmsElementResolver"/>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwBeforeAfterCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwTextVideoCmsElementResolver" public="true">
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\IctThreeColumnCmsElementResolver" public="true">
            <argument type="service" id="Shopware\Core\Content\Media\Cms\DefaultMediaResolver"/>
            <tag name="shopware.cms.data_resolver"/>
        </service>
    </services>
</container>
