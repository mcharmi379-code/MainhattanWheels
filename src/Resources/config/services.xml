<container xmlns="http://symfony.com/schema/dic/services" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <!-- Decorator -->
        <service id="MainhattanWheels\Storefront\Controller\NewsletterFormController">
            <argument type="service" id="Shopware\Core\Content\ContactForm\SalesChannel\ContactFormRoute"/>
            <argument type="service" id="Shopware\Core\Content\Newsletter\SalesChannel\NewsletterSubscribeRoute"/>
            <argument type="service" id="Shopware\Core\Content\Newsletter\SalesChannel\NewsletterUnsubscribeRoute"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <call method="setTwig">
                <argument type="service" id="twig"/>
            </call>
            <tag name="controller.service_arguments"/>
        </service>
        <!-- Resolver -->
        <service id="MainhattanWheels\Core\Content\Media\Cms\mainhattanImageTextCmsElementResolver">
            <tag name="shopware.cms.data_resolver"/>
            <argument type="service" id="Shopware\Core\Content\Media\Cms\DefaultMediaResolver"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Media\Cms\IctHeroSectionElementDataResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\Helper\Category\ResolveCategoryEntity"/>
        <service id="MainhattanWheels\Core\Content\Cms\Helper\Category\MapCategoryCard">
            <argument type="service" id="MainhattanWheels\Core\Content\Cms\Helper\Category\ResolveCategoryEntity"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\Helper\Category\BuildCategoryCard">
            <argument type="service" id="MainhattanWheels\Core\Content\Cms\Helper\Category\MapCategoryCard"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\Helper\Category\ExtractCategoryIds"/>
        <service id="MainhattanWheels\Core\Content\Cms\IctCategoryImageSliderCmsElementResolver">
            <tag name="shopware.cms.data_resolver"/>
            <argument type="service" id="MainhattanWheels\Core\Content\Cms\Helper\Category\ExtractCategoryIds"/>
            <argument type="service" id="MainhattanWheels\Core\Content\Cms\Helper\Category\BuildCategoryCard"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MainhattanIconFeatureBarCmsElementResolver">
            <argument>%kernel.project_dir%</argument>
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwCategoryShowcaseCmsElementResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwDualCardCmsElementResolver">
            <argument>%kernel.project_dir%</argument>
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwTripleCardCmsElementResolver">
            <argument>%kernel.project_dir%</argument>
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="MainhattanWheels\Core\Content\Cms\DataResolver\Element\MwHeroBannerCmsElementResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
    </services>
</container>
